      "boundElements": null,
      "updated": 1700000000000,
      "link": null,
      "locked": false,
      "text": "Docker Container = a box with everything inside:\n\n  Python 3.12  (exact version)\n  + all libraries  (exact versions)\n  + built frontend  (React app, compiled)\n  + our code\n\nRuns identically on ANY machine.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "container-concept",
      "originalText": "Docker Container = a box with everything inside:\n\n  Python 3.12  (exact version)\n  + all libraries  (exact versions)\n  + built frontend  (React app, compiled)\n  + our code\n\nRuns identically on ANY machine.",
      "autoResize": true,
      "lineHeight": 1.25
    },
