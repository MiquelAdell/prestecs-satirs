    {
      "id": "analogy-t",
      "type": "text",
      "x": 705,
      "y": 100.0,
      "width": 272.8,
      "height": 300.0,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
