{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "backend-developer": {
            "description": "Backend developer specializing in Python APIs, server logic, authentication, and service architecture",
            "mode": "subagent",
            "prompt": "{file:.agents/agents/backend-developer.md}",
            "tools": {
                "Read": true,
                "Write": true,
                "Edit": true,
                "Bash": true,
                "Glob": true,
                "Grep": true
            }
        },
        "team-leader": {
            "description": "Team leader that coordinates development work, manages tasks locally, and facilitates communication between agents",
            "mode": "primary",
            "prompt": "{file:.agents/agents/team-leader.md}",
            "tools": {
                "Read": true,
                "Glob": true,
                "Grep": true,
                "Bash": true,
                "TodoWrite": true,
                "Task": true
            }
        },
        "frontend-developer": {
            "description": "Frontend developer specializing in React, TypeScript, UI/UX implementation, and web performance",
            "mode": "subagent",
            "prompt": "{file:.agents/agents/frontend-developer.md}",
            "tools": {
                "Read": true,
                "Write": true,
                "Edit": true,
                "Bash": true,
                "Glob": true,
                "Grep": true
            }
        },
        "tester": {
            "description": "QA tester specializing in test planning, test case creation, and test execution",
            "mode": "subagent",
            "prompt": "{file:.agents/agents/tester.md}",
            "tools": {
                "Read": true,
                "Write": true,
                "Edit": true,
                "Bash": true,
                "Glob": true,
                "Grep": true
            }
        },
        "code-reviewer": {
            "description": "Code reviewer that analyzes code quality, best practices, potential bugs, and provides constructive feedback",
            "mode": "subagent",
            "prompt": "{file:.agents/agents/code-reviewer.md}",
            "tools": {
                "Read": true,
                "Glob": true,
                "Grep": true,
                "Bash": true
            }
        }
    }
}
